# Servidor HTTP
PORT=3001

# Use un valor largo, aleatorio y diferente en cada entorno.
# Ejemplo para generarlo: openssl rand -hex 64
JWT_SECRET=reemplace_con_un_secreto_aleatorio
JWT_EXPIRATION=24h

# Orígenes permitidos, separados por comas y sin barra final.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Opcional: necesario para el inicio de sesión con Google.
GOOGLE_CLIENT_ID=

# Cuentas locales para demostración. Mantenga false en producción.
SEED_DEMO_USERS=false
DEMO_ADMIN_PASSWORD=
DEMO_OPERATOR_PASSWORD=
DEMO_USER_PASSWORD=
DEMO_UNIT_PASSWORD=
